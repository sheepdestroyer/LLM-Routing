global
    log /dev/log local0
    log /dev/log local1 notice
    chroot /var/lib/haproxy
    user haproxy
    group haproxy
    daemon

    # Modern TLS profile
    ssl-default-bind-ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256
    ssl-default-bind-options no-sslv3 no-tlsv10 no-tlsv11

defaults
    log     global
    mode    http
    option  httplog
    option  dontlognull
    timeout connect 5000ms
    timeout client  300000ms    # Extended timeout matching LLM responses
    timeout server  300000ms

# --- FRONTEND (Unified Entry Point) ---
frontend api_gateway
    bind *:443 ssl crt /etc/ssl/certs/gateway.pem
    bind *:80
    redirect scheme https code 301 if !{ ssl_fc }
    
    # Route to Triage Router
    default_backend triage_routers

# --- BACKENDS (Dynamic Triage Routers) ---
backend triage_routers
    balance roundrobin
    option httpchk GET /health
    http-check expect status 200
    
    # consul-template loops through active services registered in Consul
    {{range service "llm-triage-router"}}
    server {{.ID}} {{.Address}}:{{.Port}} check inter 2000 fall 2 rise 2
    {{else}}
    # Fallback to local offline maintenance page if all backends fail
    server local-backup 127.0.0.1:8081 backup
    {{end}}
