{
  "service": {
    "name": "llm-triage-router",
    "tags": ["production", "gateway", "v1"],
    "port": 5000,
    "checks": [
      {
        "id": "router-http-check",
        "name": "Router HTTP Liveness Probe",
        "http": "http://localhost:5000/health",
        "method": "GET",
        "interval": "5s",
        "timeout": "2s",
        "deregister_critical_service_after": "30s"
      }
    ]
  }
}
